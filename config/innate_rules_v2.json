{
  "schema_id": "innate_rules_v2",
  "schema_version": "1.0",
  "rules": [
    {
      "rule_id": "rule::residual_dissonance",
      "enabled": true,
      "priority": 100,
      "display_name": "?????????",
      "family": "cognitive_feeling",
      "description": "?????????????????????????????????????????",
      "conditions": [
        {
          "metric": "state.prediction_overprediction_mass",
          "op": ">",
          "value": 0.16
        }
      ],
      "effects": [
        {
          "type": "set_emotion_floor",
          "channel": "dissonance",
          "formula": {
            "kind": "affine",
            "metric": "state.prediction_overprediction_mass",
            "base": 0.0,
            "factor": 0.72,
            "min": 0.0,
            "max": 1.0
          }
        },
        {
          "type": "inject_sa",
          "sa_label": "attr::dissonance",
          "display_text": "违和感",
          "when_channel": "dissonance",
          "threshold": 0.05,
          "formula": {
            "kind": "threshold_excess",
            "max": 1.0
          }
        },
        {
          "type": "append_rule_log",
          "message": "????????????"
        }
      ]
    },
    {
      "rule_id": "rule::committed_grasp",
      "enabled": true,
      "priority": 88,
      "display_name": "把握感形成",
      "family": "cognitive_feeling",
      "description": "当高承诺预测与现状逐渐对齐时，提升把握感通道，并在显著时注入可被认知的把握感实例。",
      "conditions": [
        {
          "metric": "state.prediction_committed_grasp_score",
          "op": ">",
          "value": 0.14
        }
      ],
      "effects": [
        {
          "type": "set_emotion_floor",
          "channel": "grasp",
          "formula": {
            "kind": "affine",
            "metric": "state.prediction_committed_grasp_score",
            "base": 0.0,
            "factor": 0.98,
            "min": 0.0,
            "max": 1.0
          }
        },
        {
          "type": "inject_sa",
          "sa_label": "attr::grasp",
          "display_text": "把握感",
          "when_channel": "grasp",
          "threshold": 0.14,
          "formula": {
            "kind": "threshold_excess",
            "max": 1.0
          }
        },
        {
          "type": "append_rule_log",
          "message": "高承诺预测逐渐被现状证实，把握感上升"
        }
      ]
    },
    {
      "rule_id": "rule::bn_correctness",
      "enabled": true,
      "priority": 80,
      "display_name": "稳定一级召回触发正确感",
      "family": "cognitive_feeling",
      "description": "当现状与预测重新对齐、把握感得分升高时，提高正确感通道，并在显著时注入可被认知的正确感实例。",
      "conditions": [
        {
          "metric": "state.prediction_grasp_score",
          "op": ">",
          "value": 0.18
        },
        {
          "metric": "state.prediction_alignment_score",
          "op": ">",
          "value": 0.12
        }
      ],
      "effects": [
        {
          "type": "set_emotion_floor",
          "channel": "correctness",
          "formula": {
            "kind": "affine",
            "metric": "state.prediction_grasp_score",
            "base": 0.0,
            "factor": 0.92,
            "min": 0.0,
            "max": 1.0
          }
        },
        {
          "type": "inject_sa",
          "sa_label": "attr::correctness",
          "display_text": "正确感",
          "when_channel": "correctness",
          "threshold": 0.12,
          "formula": {
            "kind": "threshold_excess",
            "max": 1.0
          }
        },
        {
          "type": "append_rule_log",
          "message": "现状与预测重新对齐，正确感上升"
        }
      ]
    },
    {
      "rule_id": "rule::cstar_expectation",
      "enabled": true,
      "priority": 70,
      "display_name": "预测包触发期待",
      "family": "prediction",
      "description": "当综合预测包不仅存在，而且与当前现状有一定自洽度时，提升期待通道，并在显著时注入期待实例。",
      "conditions": [
        {
          "metric": "c_star.count",
          "op": ">",
          "value": 0.0
        },
        {
          "metric": "state.prediction_alignment_score",
          "op": ">",
          "value": 0.08
        }
      ],
      "effects": [
        {
          "type": "set_emotion_floor",
          "channel": "expectation",
          "formula": {
            "kind": "affine",
            "metric": "c_star.top_energy",
            "base": 0.0,
            "factor": 0.2,
            "min": 0.0,
            "max": 1.0
          }
        },
        {
          "type": "inject_sa",
          "sa_label": "attr::expectation",
          "display_text": "期待",
          "when_channel": "expectation",
          "threshold": 0.12,
          "formula": {
            "kind": "threshold_excess",
            "min": 0.0,
            "max": 1.0
          }
        },
        {
          "type": "append_rule_log",
          "message": "综合预测包已形成，期待上升"
        }
      ]
    },
    {
      "rule_id": "rule::dissonance_pressure",
      "enabled": true,
      "priority": 60,
      "display_name": "???????????",
      "family": "emotion",
      "description": "??????????????????????????????",
      "conditions": [
        {
          "metric": "emotion.surprise_plus_dissonance",
          "op": ">",
          "value": 0.2
        }
      ],
      "effects": [
        {
          "type": "set_emotion_floor",
          "channel": "pressure",
          "formula": {
            "kind": "mul",
            "metric": "emotion.surprise_plus_dissonance",
            "factor": 0.55,
            "min": 0.0,
            "max": 1.0
          }
        },
        {
          "type": "inject_sa",
          "sa_label": "attr::pressure",
          "display_text": "压力",
          "when_channel": "pressure",
          "threshold": 0.05,
          "formula": {
            "kind": "threshold_excess",
            "max": 1.0
          }
        },
        {
          "type": "append_rule_log",
          "message": "???????????"
        }
      ]
    },
    {
      "rule_id": "rule::continue_focus_drive",
      "enabled": true,
      "priority": 50,
      "display_name": "期待大于压力时继续聚焦",
      "family": "action_drive",
      "description": "当期待强于压力且已有一级召回时，提高继续聚焦动作的驱动力。",
      "conditions": [
        {
          "metric": "bn.count",
          "op": ">",
          "value": 0.0
        },
        {
          "metric": "emotion.expectation_minus_pressure",
          "op": ">",
          "value": 0.0
        }
      ],
      "effects": [
        {
          "type": "add_action_drive",
          "action_id": "action::continue_focus",
          "reason": "预测连续性较强",
          "params": {},
          "formula": {
            "kind": "max_metric",
            "metrics": [
              "emotion.expectation",
              "emotion.expectation_minus_pressure"
            ],
            "max": 1.0
          }
        }
      ]
    },
    {
      "rule_id": "rule::grasp_continue_focus_drive",
      "enabled": true,
      "priority": 56,
      "display_name": "把握形成时更容易延续动作",
      "family": "action_drive",
      "description": "当把握感较高时，对当前主线动作提供额外驱动力，降低行动犹豫。",
      "conditions": [
        {
          "metric": "emotion.grasp",
          "op": ">",
          "value": 0.16
        }
      ],
      "effects": [
        {
          "type": "add_action_drive",
          "action_id": "action::continue_focus",
          "reason": "已有把握，延续当前观察/思路",
          "params": {},
          "formula": {
            "kind": "metric",
            "metric": "emotion.grasp",
            "min": 0.0,
            "max": 1.0
          }
        }
      ]
    },
    {
      "rule_id": "rule::vision_continue_focus_drive",
      "enabled": true,
      "priority": 55,
      "display_name": "视觉输入下优先继续聚焦",
      "family": "action_drive",
      "description": "当存在图像输入、已有一级召回且期待不低于压力时，提高 continue_focus 的驱动力，让多 tick 观察更容易形成仔细看闭环。",
      "conditions": [
        {
          "metric": "modal.has_image",
          "op": "==",
          "value": 1.0
        },
        {
          "metric": "bn.count",
          "op": ">",
          "value": 0.0
        },
        {
          "metric": "emotion.expectation_minus_pressure",
          "op": ">=",
          "value": 0.0
        }
      ],
      "effects": [
        {
          "type": "add_action_drive",
          "action_id": "action::continue_focus",
          "reason": "视觉对象需要连续观察",
          "params": {},
          "formula": {
            "kind": "affine",
            "metric": "emotion.expectation",
            "base": 0.28,
            "factor": 0.72,
            "min": 0.0,
            "max": 1.0
          }
        }
      ]
    },
    {
      "rule_id": "rule::inspect_residual_drive",
      "enabled": true,
      "priority": 40,
      "display_name": "违和感较高时回看残留",
      "family": "action_drive",
      "description": "当违和感较高时，为 inspect_residual 注入驱动力。",
      "conditions": [
        {
          "metric": "emotion.dissonance",
          "op": ">",
          "value": 0.3
        }
      ],
      "effects": [
        {
          "type": "add_action_drive",
          "action_id": "action::inspect_residual",
          "reason": "残留较高，需要回看",
          "params": {},
          "formula": {
            "kind": "metric",
            "metric": "emotion.dissonance",
            "min": 0.0,
            "max": 1.0
          }
        }
      ]
    },
