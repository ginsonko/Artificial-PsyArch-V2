{
  "label": "Phase20+ 持续自主 Session 数据集样例",
  "config_overrides": {
    "executor_enabled": false,
    "executor_screenshot_enabled": false,
    "autonomous_capture_required": false
  },
  "runs": [
    {
      "mode": "autonomous_session",
      "label": "autonomous session start",
      "tick_interval_ms": 10,
      "max_ticks": 4,
      "text_hint": "持续观察当前环境并维持焦点",
      "after": {
        "status_snapshot": {
          "path": "../outputs/autonomous_session_start_status.json"
        },
        "wait_for_session": {
          "timeout_sec": 30
        },
        "save_checkpoint_path": "../outputs/autonomous_session_runtime_checkpoint.json"
      }
    }
  ]
}
