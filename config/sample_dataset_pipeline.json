{
  "label": "Phase16 数据集管线样例",
  "runs": [
    {
      "label": "pipeline step 1",
      "texts": [
        "今天 天气 不错",
        "我 想 出门"
      ],
      "after": {
        "save_checkpoint_path": "../outputs/runtime_checkpoint_pipeline.json",
        "export_memory_bundle_dir": "../outputs/memory_bundle_pipeline",
        "inspect_memory_bundle": true
      }
    },
    {
      "label": "pipeline step 2",
      "mode": "continue_from_checkpoint",
      "checkpoint_path": "../outputs/runtime_checkpoint_pipeline.json",
      "texts": [
        "今天 天气 有点 冷",
        "算了 不说了"
      ],
      "after": {
        "forget": {
          "keep_latest": 8,
          "strategy": "score_prune",
          "min_reality_weight": 0.4,
          "min_total_item_energy": 0.2,
          "protect_memory_kinds": [
            "teacher_feedback"
          ],
          "dry_run": false
        }
      }
    }
  ]
}
