{
  "type": "object",
  "required": [
    "schema_id",
    "schema_version",
    "sensor_name",
    "tick_index",
    "input_text",
    "normalized_text",
    "budget_limit",
    "budget_used",
    "total_units",
    "sa_items",
    "sampling_summary",
    "fatigue_summary"
  ],
  "properties": {
    "schema_id": { "type": "string", "enum": ["text_sensor_packet/v1"] },
    "schema_version": { "type": "string" },
    "sensor_name": { "type": "string" },
    "tick_index": { "type": "integer", "minimum": 0 },
    "input_text": { "type": "string" },
    "normalized_text": { "type": "string" },
    "budget_limit": { "type": "integer", "minimum": 0 },
    "budget_used": { "type": "integer", "minimum": 0 },
    "total_units": { "type": "integer", "minimum": 0 },
    "sa_items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["sa_label", "display_text", "energy", "position"],
        "properties": {
          "sa_label": { "type": "string" },
          "display_text": { "type": "string" },
          "energy": { "type": "number" },
          "position": { "type": "integer", "minimum": 0 }
        },
        "additionalProperties": true
      }
    },
    "sampling_summary": { "type": "object" },
    "fatigue_summary": { "type": "object" }
  },
  "additionalProperties": true
}

